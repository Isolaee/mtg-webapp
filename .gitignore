# Rust
backend-rust/target/

# Node modules
frontend/node_modules/
node_modules/

# Build output
frontend/build/
frontend/dist/
*.log

# OS files
.DS_Store
Thumbs.db

# IDE/editor files
.vscode/
.idea/
*.swp

# Environment variables and secrets
.env
.env.*

# Beads / Dolt files (added by bd init)
.dolt/
.beads-credential-key

# Python bytecode
__pycache__/
